# Backend local environment variables for SkiilEX
# Copy this file to backend/.env and fill your real values.
# backend/.env is gitignored.

# Database
DB_URL=jdbc:mysql://localhost:3306/skillex?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# JWT
APP_JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
APP_JWT_EXPIRATION_MS=86400000

# Embedding provider: local | api
EMBEDDING_PROVIDER=local
EMBEDDING_FALLBACK_TO_LOCAL=true
# Set either GEMINI_API_KEY (global) or EMBEDDING_API_KEY (embedding-specific override).
GEMINI_API_KEY=
EMBEDDING_API_KEY=
EMBEDDING_API_MODEL=gemini-embedding-001
EMBEDDING_API_TIMEOUT_MS=8000

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional CORS override
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
