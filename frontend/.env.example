# ──────────────────────────────────────────────────────────────
# SkillEX — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
#
# Stack: React (Vite) + Spring Boot + MySQL 8
# ──────────────────────────────────────────────────────────────

# ── Frontend (Vite) ────────────────────────────────────────────
# Public URL of the deployed frontend
VITE_APP_URL=http://localhost:5173

# Spring Boot API base URL.
# Leave empty in dev — Vite proxies /api → http://localhost:8080 automatically.
# Set to your production API URL for production builds.
VITE_API_URL=

# ── Spring Boot Backend ────────────────────────────────────────
# (These are loaded by Spring Boot, not Vite — put them in
#  src/main/resources/application-local.properties on the Java side)

# MySQL DataSource
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/skillex?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your_password

# JWT Secret (min 32 chars, use a strong random value)
# JWT_SECRET=change_me_to_a_long_random_secret_string_here
# JWT_EXPIRATION_MS=86400000

# Google OAuth2 (Spring Security)
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret