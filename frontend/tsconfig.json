{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
      "@data/*": ["../database/*"],
      "@config/*": ["./src/config/*"],
      "@scripts/*": ["../scripts/*"],
      "date-fns": ["./node_modules/date-fns/index.d.ts"],
      "date-fns/*": ["./node_modules/date-fns/*"],
      "zod": ["./node_modules/zod/index.d.ts"],
      "zod/*": ["./node_modules/zod/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": ["node_modules"]
}
